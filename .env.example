# ============================================================
# WALLED LAKE MASONS — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.
# ============================================================

# --- App ---
NEXT_PUBLIC_SITE_URL=https://www.walledlakemasons.com
NODE_ENV=development
STAGING=false                  # set to "true" on staging deployments

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/walledlakemasons?schema=public"

# --- NextAuth / Auth.js ---
AUTH_SECRET="your-secret-at-least-32-chars-random"
AUTH_URL=http://localhost:3000  # production: https://www.walledlakemasons.com

# --- Sanity CMS ---
NEXT_PUBLIC_SANITY_PROJECT_ID="your-sanity-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-01-01"
SANITY_API_TOKEN="your-sanity-read-token"   # server-side only

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Google Analytics ---
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# --- Email (SMTP) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="lodge@walledlakemasons.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="Walled Lake Lodge <noreply@walledlakemasons.com>"
HALL_RENTAL_EMAIL="rental@walledlakemasons.com"
ADMIN_EMAIL="secretary@walledlakemasons.com"

# --- Staging password protection ---
STAGING_PASSWORD="changeme"
