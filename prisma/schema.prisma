// Walled Lake Masons — Prisma Schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  MEMBER
  ADMIN
}

enum CommentStatus {
  PENDING
  APPROVED
  REMOVED
}

enum CommentEntityType {
  EVENT
  ANNOUNCEMENT
}

enum RSVPStatus {
  ATTENDING
  DECLINED
  WAITLIST
}

enum EventVisibility {
  PUBLIC
  MEMBER
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ============================================================
// AUTH MODELS (Auth.js / NextAuth compatible)
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// USER / MEMBER
// ============================================================

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  passwordHash     String?
  name             String?
  displayName      String?
  phone            String?
  role             Role      @default(MEMBER)
  approved         Boolean   @default(false)
  commentApproved  Boolean   @default(false) // first comment approval gate
  bio              String?   @db.Text
  title            String?   // lodge title / officer position
  profileVisible   Boolean   @default(true)  // member directory privacy
  joinedLodge      String?   // year joined lodge
  image            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  accounts    Account[]
  sessions    Session[]
  comments    Comment[]
  rsvps       RSVP[]
  volunteers  Volunteer[]
  donations   Donation[]
  removedComments Comment[] @relation("RemovedBy")
}

// ============================================================
// EVENTS
// ============================================================

model Event {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  description String?         @db.Text
  startAt     DateTime
  endAt       DateTime?
  location    String?
  address     String?
  visibility  EventVisibility @default(PUBLIC)
  maxAttendees Int?
  icsUid      String          @unique @default(cuid())
  sanityId    String?         @unique // CMS reference
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  rsvps      RSVP[]
  volunteers Volunteer[]
  comments   Comment[]
}

// ============================================================
// RSVP
// ============================================================

model RSVP {
  id        String     @id @default(cuid())
  userId    String
  eventId   String
  status    RSVPStatus @default(ATTENDING)
  note      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

// ============================================================
// VOLUNTEER
// ============================================================

model Volunteer {
  id         String   @id @default(cuid())
  userId     String
  eventId    String
  role       String?  // what they volunteered for
  note       String?
  createdAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

// ============================================================
// COMMENTS (members-only, threaded)
// ============================================================

model Comment {
  id          String            @id @default(cuid())
  entityType  CommentEntityType
  entityId    String            // eventId or sanity announcement id
  authorId    String
  parentId    String?
  content     String            @db.Text
  status      CommentStatus     @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  removedAt   DateTime?
  removedById String?

  author   User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent   Comment? @relation("Replies", fields: [parentId], references: [id])
  replies  Comment[] @relation("Replies")
  removedBy User?   @relation("RemovedBy", fields: [removedById], references: [id])

  // For event comments, link to local Event table if available
  event    Event?   @relation(fields: [entityId], references: [id], map: "comment_event_fk")

  @@index([entityType, entityId])
  @@index([authorId])
  @@index([status])
}

// ============================================================
// DONATIONS
// ============================================================

model Donation {
  id               String         @id @default(cuid())
  userId           String?
  stripeSessionId  String         @unique
  stripePaymentId  String?
  amount           Int            // cents
  currency         String         @default("usd")
  status           DonationStatus @default(PENDING)
  donorName        String?
  donorEmail       String?
  message          String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ============================================================
// HALL RENTAL INQUIRIES
// ============================================================

model HallRentalInquiry {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  eventDate   DateTime
  eventType   String
  guestCount  Int?
  message     String   @db.Text
  responded   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  target    String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
}
